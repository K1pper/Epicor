string errorEmail = userCode.FirstOrDefault(r => r.CodeID == "ErrEmail").CodeDesc;

// query GHA_SalesOrderReport BAQ and build a datatable
EnumerableRowCollection<DataRow> result;
var db = Ice.Services.ContextFactory.CreateContext<IceContext>();
using (var dynamicQuerySvc = Ice.Assemblies.ServiceRenderer.GetService<Ice.Contracts.DynamicQuerySvcContract>(db))  
{  
  var baqExecutionParams = dynamicQuerySvc.GetQueryExecutionParametersByID("GHA_SalesOrderReport");  

  DataSet executeResult = dynamicQuerySvc.ExecuteByID("GHA_SalesOrderReport", baqExecutionParams);
  result = executeResult.Tables["Results"].AsEnumerable();
}

List<DataRow> nonErrorRows = result.Where(r => r["Calculated_Error"] == "").ToList();
nonErrorRows = trimColumns(nonErrorRows, false);

List<DataRow> errorRows = result.Where(r => r["Calculated_Error"] != "").ToList();
errorRows = trimColumns(errorRows, true);

if (errorRows.Count > 0)
{
  string csv = rowsToCsv(errorRows);
  Dictionary<string, byte[]> attachment = csvToAttachment(csv, true);

  // recipient has to be a list, presumably for bulk emailing. unsure if a work-around (apart from the below) exists
  sendEmail(senderEmail, new List<string>() { errorEmail }, "Sales Order Reporting Errors", "See attached.", attachment);
}

Dictionary<string, List<DataRow>> recipientsToReport = nonErrorRows.GroupBy(row => row["Email Address"].ToString())
                                                                   .ToDictionary(g => g.Key, g => g.ToList());

foreach (KeyValuePair<string, List<DataRow>> kvp in recipientsToReport)
{
  string csv = rowsToCsv(kvp.Value);
  Dictionary<string, byte[]> attachment = csvToAttachment(csv, false);
  
  sendEmail(senderEmail, new List<string> { kvp.Key }, "Sales Order Report", "See attached.", attachment);
}